{
  "manifest_version": 3,
  "name": "Privacy Lens",
  "version": "1.0.0",
  "description": "This tool will analyze the privacy policy for websites you visit and summarize it so that you know what data gets collected from you.",
  "action": {
    "default-title": "Privacy Lens",
    "default_popup": "index.html",
    "default_icon": "src/extension/assets/icon-128.png"
  },
  "icons": {
    "16": "src/extension/assets/icon-16.png",
    "32": "src/extension/assets/icon-32.png",
    "48": "src/extension/assets/icon-48.png",
    "128": "src/extension/assets/icon-128.png"
  },

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extension/contentScript.ts"]
    }
  ],
  "host_permissions": ["<all_urls>", "https://openrouter.ai/*"],
  "background": {
    "service_worker": "src/extension/background.ts",
    "type": "module"
  }
}
