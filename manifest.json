{
  "manifest_version": 3,
  "name": "Privacy Lens - What Sites Collect",
  "version": "1.0.0",
  "description": "Instant AI summaries of privacy policies see exactly what data sites collect & share, with simple icons & plain English. Take back control!",
  "action": {
    "default-title": "Privacy Lens",
    "default_popup": "index.html",
    "default_icon": "src/shared/assets/icon-128.png"
  },
  "icons": {
    "16": "src/shared/assets/icon-16.png",
    "32": "src/shared/assets/icon-32.png",
    "48": "src/shared/assets/icon-48.png",
    "128": "src/shared/assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://privacy-lens.slo7i-b-sb.workers.dev/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  }
}