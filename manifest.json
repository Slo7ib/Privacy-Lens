{
  "manifest_version": 3,
  "name": "Privacy Lens",
  "version": "1.0.0",
  "description": "This tool will analyze the privacy policy for websites you visit and summarize it so that you know what data gets collected from you.",
  "action": {
    "default-title": "Privacy Lens",
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/contentScript.ts"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  }
}
